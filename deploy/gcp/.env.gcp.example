# XActions API — external credentials for the Cloud Run backend.
#
# Copy to deploy/gcp/.env.gcp (gitignored) and fill in only what you need, then
# run:  PROJECT_ID=your-project bash deploy/gcp/deploy.sh
#
# Every value here is pushed to Secret Manager and wired into the service.
# LEAVE A LINE BLANK/ABSENT to skip it — the deploy still succeeds, that feature
# just stays off. With none of these, the read surface (scrapers, analytics,
# paid x402 reads) works; auth/billing come online as you add creds.

# ── Database: user accounts, unfollower history, licenses ────────────────────
# Any Postgres URL (Neon, Supabase, Cloud SQL). start.sh runs prisma migrate
# deploy automatically on boot when this is set.
DATABASE_URL=

# ── Sign in with X (OAuth 2.0) ───────────────────────────────────────────────
# From https://developer.x.com → your app → OAuth 2.0 Client ID/Secret.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ── x402 payouts (optional; a sensible mainnet default is used otherwise) ─────
# The address paid x402 API revenue settles to.
X402_PAY_TO_ADDRESS=
